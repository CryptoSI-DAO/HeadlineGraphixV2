# Public-safe values (baked into client JS bundle at build time)
# The anon key is public by design — RLS policies enforce actual security.
# Using RELATIVE path so browser always uses same origin — no CORS/redirect issues.
NEXT_PUBLIC_SUPABASE_URL=/supabase-proxy
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...-RCM
